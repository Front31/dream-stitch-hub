# Shopify Storefront API Konfiguration
# Kopiere diese Datei zu .env und trage deine eigenen Werte ein.
#
# Store-Domain: Deine myshopify.com Domain (ohne https://)
# Storefront Token: Findest du im Shopify Admin unter: Settings > Apps > Develop apps > Storefront API
#
VITE_SHOPIFY_STORE_DOMAIN=dein-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=dein-storefront-access-token
